# ─────────────────────────────────────────────────────────────────────
# cosmic_docs_pipeline — environment template
# Copy to .env and fill in the keys for the providers you actually use.
# ─────────────────────────────────────────────────────────────────────

# ── Channel ─────────────────────────────────────────────────────────
TARGET_MINUTES=22

# ── LLM (script + video-prompt generation) ──────────────────────────
# Run one or many in parallel (comma-separated) to pick the best variant.
LLM_PROVIDERS=gemini,openai,claude
LLM_SELECTED=claude

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── TTS ─────────────────────────────────────────────────────────────
# Default: xtts  (offline, voice cloning, free)
# Alternatives: piper | gemini | elevenlabs | f5
TTS_PROVIDER=xtts

# Provider-specific voice selector
#   xtts         — leave blank to use TTS_REFERENCE_WAV for cloning
#   piper        — voice model name (e.g. hi_IN-priyamvada-medium)
#   gemini       — Charon | Rasalgethi | Gacrux | Zephyr | Puck ...
#   elevenlabs   — voice id
#   f5           — leave blank to use TTS_REFERENCE_WAV for cloning
TTS_VOICE=

# 10-20 s clean sample for voice cloning (xtts / f5 / elevenlabs-ivc)
TTS_REFERENCE_WAV=voices/narrator.wav

# Language code for XTTS (hi = Hindi, en = English)
TTS_LANGUAGE=hi

# ElevenLabs-specific (only needed when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Audio post-processing (silence trimming) ────────────────────────
# Drops any silence longer than N seconds below the threshold.
SILENCE_TRIM_DURATION=0.35
SILENCE_TRIM_THRESHOLD_DB=-38

# ── Video ───────────────────────────────────────────────────────────
# Default: meta_ai (free, 5s cap — scene-continuation enabled)
# Alternatives: kling | sora | veo | runway | wan
VIDEO_PROVIDER=meta_ai

# Leave blank to auto-pick from the provider (meta_ai=5, kling=60, ...)
VIDEO_MAX_CLIP_SEC=

# Meta AI cookies (required if VIDEO_PROVIDER=meta_ai)
META_AI_DATR=
META_AI_ECTO_1_SESS=
META_AI_ABRA_SESS=
META_AI_RD_CHALLENGE=
META_AI_DPR=
META_AI_WD=

# Kling (if VIDEO_PROVIDER=kling)
KLING_API_KEY=
KLING_MODEL=kling-v2.6

# Sora (if VIDEO_PROVIDER=sora)
SORA_API_KEY=

# Veo (uses Gemini API key above)
VEO_MODEL=veo-3.1

# Runway (if VIDEO_PROVIDER=runway)
RUNWAY_API_KEY=
RUNWAY_MODEL=gen-4

# WAN 2.5 (if VIDEO_PROVIDER=wan)
WAN_API_KEY=
WAN_API_BASE=

# ── Thumbnail (optional Stage 8) ────────────────────────────────────
THUMB_PROVIDER=gemini_image

# ── YouTube upload ──────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secret.json
YOUTUBE_PRIVACY=private
YOUTUBE_OAUTH_BROWSER=

# ── FFmpeg ──────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
