{
  "manifest_version": 3,
  "name": "Gemini Image Studio",
  "version": "2.1.0",
  "description": "AI image production studio — batch Gemini generation, ZIP export, character consistency, templates, multi-provider ready.",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Gemini Image Studio"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "lib/providers/geminiProvider.js",
        "lib/providers/chatgptProvider.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.googleusercontent.com/*",
    "https://lh3.googleusercontent.com/*",
    "https://*.oaiusercontent.com/*",
    "https://*.openai.com/*"
  ]
}
