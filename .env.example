# Meta AI cookies — required for video generation.
#
# How to get them:
#   1. Visit https://meta.ai in your browser and log in
#   2. Open DevTools (F12) → Application tab → Cookies → https://meta.ai
#   3. Copy the values listed below
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required cookies ──────────────────────────────────────────────────
META_AI_DATR=your_datr_cookie_here
META_AI_ECTO_1_SESS=your_ecto_1_sess_cookie_here

# ── Optional cookies (include if present in your browser) ────────────
# META_AI_ABRA_SESS=your_abra_sess_cookie_here
META_AI_RD_CHALLENGE=your_rd_challenge_cookie_here
META_AI_DPR=1
# META_AI_WD=1870x628
